#!/bin/bash

BUILD_LOG=build.log
SHARD_SUMMARY=target/shard-summary.md

ARGUMENTS="clean verify -B -T 1.5C -U"
if [ $# -ge 1 ]; then
    ARGUMENTS=$@
fi

function build_parts() {
    local parts="${MAVEN_BUILD_PARTS:-1}"
    if ! [[ "$parts" =~ ^[1-9][0-9]*$ ]]; then
        parts=1
    fi
    echo "$parts"
}

function build_part() {
    local part="${MAVEN_BUILD_PART:-1}"
    local parts=$(build_parts)
    if ! [[ "$part" =~ ^[1-9][0-9]*$ ]] || [ "$part" -gt "$parts" ]; then
        part=1
    fi
    echo "$part"
}

function write_shard_summary() {
    local mode="$1"
    local scope="$2"
    local addon_count="$3"
    local range="$4"
    local indices="$5"

    mkdir -p "$(dirname "$SHARD_SUMMARY")"

    {
        echo "### Build Shard"
        echo "- Shard: $(build_part)/$(build_parts)"
        echo "- Mode: $mode"
        echo "- Scope: $scope"
        if [ -n "$addon_count" ]; then
            echo "- Add-ons: $addon_count"
        fi
        if [ -n "$indices" ]; then
            echo "- Alphabetical slice indices: $indices"
        fi
        if [ -n "$range" ]; then
            echo "- Alphabetical range: $range"
        fi
    } > "$SHARD_SUMMARY"
}

function print_reactor_summary() {
    local start_end=$(grep -anE "\[INFO\] \\-{70,}" "$BUILD_LOG" | tail -n4 | cut -f1 -d: | sed -e 1b -e '$!d' | xargs)
    local start=$(awk '{print $1}' <<< $start_end)
    local end=$(awk '{print $2}' <<< $start_end)
    cat "$BUILD_LOG" | sed -n "${start},${end}p" | sed 's/\[INFO\] //'
}

gha_escape() {
  sed -e 's/%/%25/g' -e 's/\r/%0D/g' -e 's/\n/%0A/g'
}

emit_markdownlint_annotations() {
  [[ -f "$BUILD_LOG" ]] || return 0

  while IFS= read -r l; do
    file=$(echo "$l" | sed -E 's/^([^:]+\.md):.*/\1/')
    line=$(echo "$l" | sed -E 's/^[^:]+\.md:([0-9]+).*/\1/')

    # Repair path so GitHub can link it (repo-root relative)
    if [[ ! -f "$file" ]]; then
      if [[ -f "bundles/$file" ]]; then
        file="bundles/$file"
      elif [[ -f "itests/$file" ]]; then
        file="itests/$file"
      fi
    fi

    if echo "$l" | grep -qE '^[^:]+\.md:[0-9]+:[0-9]+ error MD'; then
      col=$(echo "$l" | sed -E 's/^[^:]+\.md:[0-9]+:([0-9]+) error .*/\1/')
      rule=$(echo "$l" | sed -E 's/^[^:]+\.md:[0-9]+:[0-9]+ error (MD[^ ]+) .*/\1/')
      rest=$(echo "$l" | sed -E 's/^[^:]+\.md:[0-9]+:[0-9]+ error MD[^ ]+ (.*)$/\1/')
      rest_esc=$(printf '%s' "$rest" | gha_escape)
      echo "::error file=$file,line=$line,col=$col,title=$rule::$rest_esc"
    else
      rule=$(echo "$l" | sed -E 's/^[^:]+\.md:[0-9]+ error (MD[^ ]+) .*/\1/')
      rest=$(echo "$l" | sed -E 's/^[^:]+\.md:[0-9]+ error MD[^ ]+ (.*)$/\1/')
      rest_esc=$(printf '%s' "$rest" | gha_escape)
      echo "::error file=$file,line=$line,title=$rule::$rest_esc"
    fi
  done < <(
    grep -aE '\[INFO\] .*\.md:[0-9]+(:[0-9]+)? error MD' "$BUILD_LOG" \
    | sed -E 's/^.*\[INFO\] //'
  )
}

function mvnp() {
  set -o pipefail # exit build with error when pipes fail
  local reactor_size=$(find -name "pom.xml" | grep -vE '/src/|/target/' | wc -l)
  local padding=$(bc -l <<< "scale=0;2*(l($reactor_size)/l(10)+1)")
  local command=(bash ./mvnw "$@")

  "${command[@]}" 2>&1 | # execute, redirect stderr to stdout
    tee "$BUILD_LOG" | # write output to log
    stdbuf -oL grep -aE '^\[INFO\] Building .+ \[.+\]$' | # filter progress
    stdbuf -o0 sed -uE 's/^\[INFO\] Building (.*[^ ])[ ]+\[([0-9]+\/[0-9]+)\]$/\2| \1/' | # prefix project name with progress
    stdbuf -o0 sed -e :a -e "s/^.\{1,${padding}\}|/ &/;ta" # right align progress with padding

  # Exit code of Maven is the first command in the pipeline
  return "${PIPESTATUS[0]}"
}

function build_all() {
    echo
    echo "Building all projects"
    echo
    echo "+ ./mvnw $ARGUMENTS"
    echo

    write_shard_summary "full-build" "all projects" "" "" ""

    mvnp $ARGUMENTS

    status=$?
    echo

	emit_markdownlint_annotations

    if [ $status -eq 0 ]; then
        print_reactor_summary
    else
        tail -n 2000 "$BUILD_LOG"
    fi

    exit $status
}

function changed_files() {
    sed 's#,#\n#g' <<< $CHANGED_FILES
}

function addon_unrelated_changed_files() {
    local addon="$1"
    changed_files | \
        grep -Ev "^(bundles/|itests/)$addon([/.].*)?$" | \
        grep -Ev "^(CODEOWNERS|bom/openhab-addons/pom.xml|bundles/pom.xml|itests/pom.xml)$"
}

function changed_addons() {
    changed_files | grep -E '(bundles/|itests/)org\.openhab\.' | sed -E 's#.+/(org\.openhab\.[a-z0-9]+\.[a-z0-9]+).*#\1#g' | sort -u
}

function all_addons() {
    find bundles itests -mindepth 1 -maxdepth 1 -type d 2>/dev/null | \
        sed -E 's#^(bundles|itests)/(org\.openhab\.[a-z0-9]+\.[a-z0-9]+).*#\2#g' | \
        grep -E '^org\.openhab\.[a-z0-9]+\.[a-z0-9]+$' | \
        sort -u
}

function addon_count() {
    all_addons | wc -l
}

function shard_range() {
    local part=$(build_part)
    local parts=$(build_parts)
    local total=$(addon_count)

    if [ "$total" -eq 0 ]; then
        echo "0 0"
        return
    fi

    local start=$(( ((part - 1) * total) / parts + 1 ))
    local end=$(( (part * total) / parts ))
    echo "$start $end"
}

function addon_assigned_to_build_part() {
    local addon="$1"
    local parts=$(build_parts)

    if [ "$parts" -le 1 ]; then
        return 0
    fi

    local index=$(all_addons | nl -ba | awk -v addon="$addon" '$2 == addon { print $1; exit }')
    if [ -z "$index" ]; then
        return 0
    fi

    local range=$(shard_range)
    local start=$(awk '{print $1}' <<< "$range")
    local end=$(awk '{print $2}' <<< "$range")

    [ "$index" -ge "$start" ] && [ "$index" -le "$end" ]
}

function sharded_addons() {
    local parts=$(build_parts)

    if [ "$parts" -le 1 ]; then
        all_addons
    else
        local range=$(shard_range)
        local start=$(awk '{print $1}' <<< "$range")
        local end=$(awk '{print $2}' <<< "$range")
        if [ "$start" -le "$end" ]; then
            all_addons | nl -ba | awk -v start="$start" -v end="$end" '$1 >= start && $1 <= end { print $2 }'
        fi
    fi
}

function addon_projects() {
    local addon="$1"

    # include add-on projects
    local projects=":$(find . -mindepth 2 -maxdepth 2 -type d -regextype egrep -regex "./(bundles|itests)/$addon(\..*)?$" | sort | sed -E 's#./(bundles|itests)/##g' | xargs | sed 's# #,:#g')"

    # include BOMs
    projects="$projects,:org.openhab.addons.bom.openhab-core-index,:org.openhab.addons.bom.runtime-index,:org.openhab.addons.bom.test-index"

    # exclude features
    projects="$projects,-:org.openhab.addons.reactor.features.karaf,-:org.openhab.addons.features.karaf.openhab-addons,-:org.openhab.addons.features.karaf.openhab-addons-external"

    echo $projects
}

function build_addon() {
    local addon="$1"
    local command="./mvnw $ARGUMENTS -am -amd -pl $(addon_projects $addon)"

    echo
    echo "Building add-on: $addon"
    echo
    echo "+ $command"
    echo

    write_shard_summary "single-addon" "$addon" "1" "$addon" ""

    set -o pipefail # exit build with error when pipes fail
    $command 2>&1 | tee "$BUILD_LOG"
    exit $?
}

function build_addon_shard() {
    local shard_addons=$(sharded_addons)
    local addons=$(echo "$shard_addons" | xargs)
    local part=$(build_part)
    local parts=$(build_parts)
    local range=$(shard_range)
    local start=$(awk '{print $1}' <<< "$range")
    local end=$(awk '{print $2}' <<< "$range")

    if [ -z "$addons" ]; then
        write_shard_summary "empty-shard" "no assigned add-ons" "0" "" ""
        echo "No add-ons assigned to shard $part/$parts" | tee "$BUILD_LOG"
        exit 0
    fi

    local first_addon=$(echo "$shard_addons" | head -n1)
    local last_addon=$(echo "$shard_addons" | tail -n1)
    local addon_total=$(echo "$shard_addons" | sed '/^$/d' | wc -l)

    local projects=$(for addon in $addons; do addon_projects "$addon"; done | tr ',' '\n' | sed '/^$/d' | grep -Ev '^-:org\.openhab\.addons\.reactor\.features\.karaf$|^-:org\.openhab\.addons\.features\.karaf\.openhab-addons$|^-:org\.openhab\.addons\.features\.karaf\.openhab-addons-external$' | awk '!seen[$0]++' | paste -sd, -)

    if [ "$part" -eq 1 ]; then
        projects="$projects,:org.openhab.addons.reactor.features.karaf,:org.openhab.addons.features.karaf.openhab-addons,:org.openhab.addons.features.karaf.openhab-addons-external"
    fi

    local command="./mvnw $ARGUMENTS -am -pl $projects"

    write_shard_summary "alphabetical-shard" "assigned add-ons" "$addon_total" "$first_addon .. $last_addon" "$start..$end"

    echo
    echo "Building add-on shard: $part/$parts"
    echo "Alphabetical slice indices: $start..$end ($addon_total add-ons)"
    echo "Alphabetical range: $first_addon .. $last_addon"
    echo
    echo "+ $command"
    echo

    set -o pipefail # exit build with error when pipes fail
    $command 2>&1 | tee "$BUILD_LOG"
    exit $?
}

function build_based_on_changes() {
    local changed_addon=$(changed_addons | xargs)
    if [ $(echo $changed_addon | wc -w) -eq 1 ] && \
        [ $(addon_unrelated_changed_files $changed_addon | wc -l) -eq 0 ] && \
        [ -d "./bundles/$changed_addon" ]
    then
        if addon_assigned_to_build_part "$changed_addon"; then
            build_addon $changed_addon
        else
            write_shard_summary "single-addon-skipped" "$changed_addon" "0" "" ""
            echo "Skipping add-on $changed_addon on shard $(build_part)/$(build_parts)" | tee "$BUILD_LOG"
            exit 0
        fi
    else
        if [ "$(build_parts)" -gt 1 ]; then
            build_addon_shard
        else
            build_all
        fi
    fi
}

bash ./mvnw -v
rm -f shard-summary.md
build_based_on_changes
