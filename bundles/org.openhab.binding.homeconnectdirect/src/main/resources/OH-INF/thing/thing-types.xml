		</tags>
		<command>
			<options>
				<option value="start">Start Program</option>
				<option value="pause">Pause Program</option>
				<option value="resume">Resume Program</option>
				<option value="stop">Stop Program</option>
			</options>
		</command>
		<autoUpdatePolicy>veto</autoUpdatePolicy>
	</channel-type>

