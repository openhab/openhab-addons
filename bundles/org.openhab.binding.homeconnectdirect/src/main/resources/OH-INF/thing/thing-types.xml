	<!-- Thing Types -->
	<thing-type id="dishwasher"
		extensible="switch, string, number, trigger, enum-switch, device-description-switch, device-description-string, device-description-number">
		<label>Dishwasher</label>
		<description>Dishwasher which supports Home Connect.</description>
		<semantic-equipment-tag>Dishwasher</semantic-equipment-tag>
		<channels>
			<!-- general -->
			<channel id="power-state" typeId="system.power"/>
			<channel id="remote-control-start-allowed" typeId="remote-control-start-allowed-channel"/>
			<channel id="operation-state" typeId="operation-state-channel"/>
			<channel id="door" typeId="door-channel"/>
			<channel id="command" typeId="command-channel"/>
			<channel id="raw-message" typeId="raw-message-channel"/>

			<!-- dishwasher specific -->
			<channel id="salt-lack" typeId="dishwasher-salt-lack-channel"/>
			<channel id="rinse-aid-lack" typeId="dishwasher-rinse-aid-lack-channel"/>
			<channel id="salt-nearly-empty" typeId="dishwasher-salt-nearly-empty-channel"/>
