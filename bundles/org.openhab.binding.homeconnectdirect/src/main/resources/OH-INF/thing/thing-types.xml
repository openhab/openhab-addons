			<channel id="machine-care-reminder" typeId="dishwasher-machine-care-reminder-channel"/>
			<channel id="program-phase" typeId="dishwasher-program-phase-channel"/>

			<!-- program -->
			<channel id="active-program" typeId="active-program-channel"/>
			<channel id="selected-program" typeId="selected-program-channel"/>
			<channel id="program-command" typeId="program-command-channel"/>
			<channel id="program-progress" typeId="program-progress-channel"/>
			<channel id="remaining-program-time" typeId="remaining-program-time-channel"/>

			<!-- program options -->
			<channel id="dishwasher-vario-speed-plus" typeId="dishwasher-vario-speed-plus-channel"/>
			<channel id="dishwasher-intensiv-zone" typeId="dishwasher-intensiv-zone-channel"/>
			<channel id="dishwasher-brilliance-dry" typeId="dishwasher-brilliance-dry-channel"/>
		</channels>
		<representation-property>haId</representation-property>
		<config-description-ref uri="thing-type:homeconnectdirect:appliance"/>
	</thing-type>

