	<!-- Channel Types -->
	<channel-type id="door-channel">
		<item-type>Contact</item-type>
		<label>Door</label>
		<description>The door state of the appliance.</description>
		<tags>
			<tag>Status</tag>
			<tag>OpenState</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="operation-state-channel">
		<item-type>String</item-type>
		<label>Operation State</label>
		<description>The operation state of the appliance.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="laundry-care-process-phase-channel">
		<item-type>String</item-type>
		<label>Process Phase</label>
		<description>The current process phase of the appliance.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="coffee-maker-process-phase-channel">
		<item-type>String</item-type>
		<label>Process Phase</label>
		<description>The current process phase of the coffee maker.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="remote-control-start-allowed-channel">
		<item-type>Switch</item-type>
		<label>Remote Start/Control Allowed</label>
		<description>Indicates whether remote control or remote program start is enabled.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="active-program-channel">
		<item-type>String</item-type>
		<label>Active Program</label>
		<description>The currently active program.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="selected-program-channel">
		<item-type>String</item-type>
		<label>Selected Program</label>
		<description>The currently selected program.</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<autoUpdatePolicy>veto</autoUpdatePolicy>
	</channel-type>

	<channel-type id="remaining-program-time-channel">
		<item-type>Number:Time</item-type>
		<label>Remaining Program Time</label>
		<description>The remaining program time.</description>
		<tags>
			<tag>Status</tag>
			<tag>Duration</tag>
		</tags>
		<state pattern="%d %unit%" readOnly="true"/>
	</channel-type>

	<channel-type id="program-progress-channel">
		<item-type>Number:Dimensionless</item-type>
		<label>Program Progress</label>
		<description>The program progress.</description>
		<tags>
			<tag>Status</tag>
		</tags>
		<state readOnly="true" min="0" max="100" pattern="%d %unit%"/>
	</channel-type>

	<channel-type id="program-command-channel">
		<item-type>String</item-type>
		<label>Program Command</label>
		<description>Controls the program execution.</description>
		<tags>
			<tag>Control</tag>
		</tags>
		<command>
			<options>
				<option value="start">Start Program</option>
				<option value="pause">Pause Program</option>
				<option value="resume">Resume Program</option>
			</options>
		</command>
		<autoUpdatePolicy>veto</autoUpdatePolicy>
	</channel-type>

	<channel-type id="oven-program-command-channel">
		<item-type>String</item-type>
		<label>Program Command</label>
		<description>Controls the program execution.</description>
		<tags>
