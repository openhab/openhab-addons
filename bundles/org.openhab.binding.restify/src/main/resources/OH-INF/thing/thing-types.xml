<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="restify"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<thing-type id="endpoint">
		<label>RESTify Endpoint</label>
		<description>Configurable REST endpoint that returns the output of a transformation.</description>
		<config-description>
			<parameter name="path" type="text" required="true">
				<label>Context Path</label>
				<description>Path of the endpoint. You can query it by http(s)://${oh}/restify/${path}</description>
			</parameter>
			<parameter name="method" type="text" required="true">
				<label>HTTP Method</label>
				<advanced>true</advanced>
				<description>
					HTTP method this endpoint accepts.
				</description>
				<default>GET</default>
				<limitToOptions>true</limitToOptions>
				<options>
					<option value="GET">GET</option>
					<option value="POST">POST</option>
					<option value="PUT">PUT</option>
					<option value="DELETE">DELETE</option>
				</options>
			</parameter>
			<parameter name="transformationPattern" type="text" required="true" multiple="true">
				<label>Transformation Pattern</label>
				<description>
					Transformation pattern that generates the response body. Multiple transformations can be chained by
					listing each transformation on a separate line, or by separating them with the intersection character ∩.
				</description>
			</parameter>
			<parameter name="contentType" type="text">
				<label>Content Type</label>
				<description>MIME content type returned by this endpoint.</description>
				<default>application/json</default>
				<options>
					<option value="application/json">application/json</option>
					<option value="text/plain">text/plain</option>
					<option value="text/csv">text/csv</option>
					<option value="text/html">text/html</option>
					<option value="application/xml">application/xml</option>
					<option value="text/xml">text/xml</option>
				</options>
				<advanced>true</advanced>
			</parameter>
			<parameter name="authorizationType" type="text">
				<label>Authorization Type</label>
				<description>Authorization required by this endpoint.</description>
				<default>NONE</default>
				<limitToOptions>true</limitToOptions>
				<options>
					<option value="NONE">None</option>
					<option value="BASIC">Basic</option>
					<option value="BEARER">Bearer</option>
				</options>
				<advanced>true</advanced>
			</parameter>
			<parameter name="username" type="text">
				<label>Username</label>
				<description>Basic authorization username.</description>
				<advanced>true</advanced>
			</parameter>
			<parameter name="password" type="text">
				<label>Password</label>
				<description>Basic authorization password.</description>
				<context>password</context>
				<advanced>true</advanced>
			</parameter>
			<parameter name="token" type="text">
				<label>Bearer Token</label>
				<description>Bearer authorization token.</description>
				<context>password</context>
				<advanced>true</advanced>
			</parameter>
		</config-description>
	</thing-type>
</thing:thing-descriptions>
