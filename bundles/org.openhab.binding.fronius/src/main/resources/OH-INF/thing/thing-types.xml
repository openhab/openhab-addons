	<!-- Battery Thing Type -->
	<thing-type id="battery">
		<supported-bridge-type-refs>
			<bridge-type-ref id="bridge"/>
		</supported-bridge-type-refs>
		<label>Fronius Battery</label>
		<description>Fronius Battery Device</description>
		<semantic-equipment-tag>Battery</semantic-equipment-tag>

		<channels>
			<channel id="maximum-capacity" typeId="maximum-capacity">
				<label>Maximum Capacity</label>
			</channel>
			<channel id="designed-capacity" typeId="designed-capacity">
				<label>Designed Capacity</label>
			</channel>
			<channel id="dc-current" typeId="dc-current">
				<label>DC Current</label>
			</channel>
			<channel id="dc-voltage" typeId="dc-voltage">
				<label>DC Voltage</label>
			</channel>
			<channel id="soc" typeId="batterySoc">
				<label>State of Charge</label>
			</channel>
			<channel id="status" typeId="batteryStatus">
				<label>Battery Cell Status</label>
			</channel>
			<channel id="enable" typeId="batteryEnable">
				<label>Enable</label>
			</channel>
			<channel id="temperature" typeId="batteryTemperature">
				<label>Cell Temperature</label>
			</channel>
			<channel id="timestamp" typeId="batteryTimestamp">
				<label>Timestamp</label>
			</channel>
			<channel id="soc-min" typeId="soc-min"/>
			<channel id="soc-max" typeId="soc-max"/>
			<channel id="backup-reserved-capacity" typeId="backup-reserved-capacity"/>
			<channel id="backup-critical-soc" typeId="backup-critical-soc"/>
			<channel id="charge-from-grid" typeId="charge-from-grid"/>
			<channel id="calibration" typeId="calibration"/>
			<channel id="night-preservation-limit" typeId="night-preservation-limit"/>
			<!-- Deprecated channels, replaced by the channels above -->
			<channel id="maximumCapacity" typeId="batteryMaximumCapacity">
				<label>Maximum Capacity (DEPRECATED)</label>
			</channel>
			<channel id="designedCapacity" typeId="batteryDesignedCapacity">
				<label>Designed Capacity (DEPRECATED)</label>
			</channel>
			<channel id="currentDc" typeId="idc">
				<label>DC Current (DEPRECATED)</label>
			</channel>
			<channel id="voltageDc" typeId="udc">
				<label>DC Voltage (DEPRECATED)</label>
			</channel>
		</channels>

		<properties>
			<property name="thingTypeVersion">2</property>
		</properties>

		<config-description>
			<parameter name="deviceId" type="integer">
				<label>Device ID</label>
				<description>Specific device identifier</description>
				<default>0</default>
			</parameter>
			<parameter name="batterySettingsRefreshInterval" type="integer" min="0" unit="min">
				<label>Battery Settings Refresh Interval</label>
				<description>Specifies the interval in minutes at which the battery settings channels are read from the
					inverter's
					config API. Reading them requires a login, therefore the interval should be kept high. Set to 0 to disable
					reading
					the battery settings from the inverter.</description>
				<default>5</default>
				<advanced>true</advanced>
			</parameter>
		</config-description>
	</thing-type>

