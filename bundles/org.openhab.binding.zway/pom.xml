<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.openhab.addons.bundles</groupId>
    <artifactId>org.openhab.addons.reactor.bundles</artifactId>
    <version>5.2.0-SNAPSHOT</version>
  </parent>

  <artifactId>org.openhab.binding.zway</artifactId>

  <name>openHAB Add-ons :: Bundles :: ZWay Binding</name>

  <properties>
    <dep.noembedding>commons-lang3,commons-net</dep.noembedding>
    <!-- zway-lib was compiled against Jetty 9 (org.eclipse.jetty.client.api/.util);
         those packages no longer exist in Jetty 12. Mark them optional so the bundle
         resolves in OSGi. zway-lib must be rebuilt against Jetty 12 for runtime use. -->
    <bnd.importpackage>org.eclipse.jetty.client.api;resolution:="optional",org.eclipse.jetty.client.util;resolution:="optional"</bnd.importpackage>
  </properties>

  <dependencies>
    <dependency>
      <groupId>commons-net</groupId>
      <artifactId>commons-net</artifactId>
      <version>${commons.net.version}</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>org.apache.commons</groupId>
      <artifactId>commons-lang3</artifactId>
      <version>3.20.0</version>
      <scope>compile</scope>
    </dependency>
    <dependency>
      <groupId>com.github.pathec</groupId>
      <artifactId>zway-lib</artifactId>
      <version>0.2.9.OH</version>
      <scope>compile</scope>
    </dependency>
  </dependencies>

</project>
