<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="intesis"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<channel-type id="mode">
		<item-type>String</item-type>
		<label>Unit Mode</label>
		<description>Operating mode of the Air Conditioner: AUTO/HEAT/DRY/FAN/COOL</description>
		<tags>
			<tag>Status</tag>
			<tag>Mode</tag>
		</tags>
		<state readOnly="false">
			<options>
				<option value="AUTO">Auto</option>
				<option value="COOL">Cool</option>
				<option value="DRY">Dry</option>
				<option value="FAN">Fan</option>
				<option value="HEAT">Heat</option>
			</options>
		</state>
	</channel-type>
	<channel-type id="fanSpeed">
		<item-type>String</item-type>
		<label>Fan Speed</label>
		<description>Sets the fan speed on the Air conditioner.</description>
		<tags>
			<tag>Status</tag>
			<tag>Speed</tag>
		</tags>
		<state readOnly="false"></state>
	</channel-type>
	<channel-type id="vanesUpDown">
		<item-type>String</item-type>
		<label>Vertical Swing Mode</label>
		<description>Sets the vertical (up/down)swing action on the Air Conditioner.</description>
		<tags>
			<tag>Status</tag>
			<tag>Tilt</tag>
		</tags>
		<state readOnly="false"></state>
	</channel-type>
	<channel-type id="vanesLeftRight">
		<item-type>String</item-type>
		<label>Horizontal Swing Mode</label>
		<description>Sets the horizontal (left/right) swing action on the Air Conditioner.</description>
		<tags>
			<tag>Status</tag>
			<tag>Tilt</tag>
		</tags>
		<state readOnly="false"></state>
	</channel-type>
	<channel-type id="targetTemperature">
		<item-type>Number:Temperature</item-type>
		<label>Target Temperature</label>
		<description>Sets the desired room temperature.</description>
		<tags>
			<tag>Setpoint</tag>
			<tag>Temperature</tag>
		</tags>
		<state pattern="%.1f %unit%" step="0.5" readOnly="false"></state>
	</channel-type>
	<channel-type id="ambientTemperature">
		<item-type>Number:Temperature</item-type>
		<label>Ambient Temperature</label>
		<description>Shows actual room temperature.</description>
		<tags>
			<tag>Measurement</tag>
			<tag>Temperature</tag>
		</tags>
		<state pattern="%.1f %unit%" step="0.5" readOnly="true"></state>
	</channel-type>
	<channel-type id="outdoorTemperature">
		<item-type>Number:Temperature</item-type>
		<label>Outdoor Temperature</label>
		<description>Shows actual outdoor temperature.</description>
		<tags>
			<tag>Measurement</tag>
			<tag>Temperature</tag>
		</tags>
		<state pattern="%.1f %unit%" step="0.5" readOnly="true"></state>
	</channel-type>
	<channel-type id="errorCode">
		<item-type>String</item-type>
		<label>Error Code</label>
		<description>Shows the Air Conditioners error code if an error was found.</description>
		<state readOnly="true"></state>
	</channel-type>

	<channel-type id="errorStatusSwitch">
		<item-type>Switch</item-type>
		<label>Error Status</label>
		<description>Indicates if the Air Conditioner has encountered an error.</description>
		<tags>
			<tag>Status</tag>
		</tags>
		<state readOnly="true"></state>
	</channel-type>

</thing:thing-descriptions>
