<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.openhab.addons.bundles</groupId>
    <artifactId>org.openhab.addons.reactor.bundles</artifactId>
    <version>6.0.0-SNAPSHOT</version>
  </parent>

  <artifactId>org.openhab.binding.http</artifactId>

  <name>openHAB Add-ons :: Bundles :: HTTP Binding</name>

  <properties>
    <!-- Compiled against Jetty 12.1.8 (WireMock test requirement) but runtime provides 12.0.23; lower the floor -->
    <bnd.importpackage>org.eclipse.jetty.*;version="[12.0,13)"</bnd.importpackage>
  </properties>

  <!-- WireMock 4.x is compiled against Jetty 12.1.8; override the parent BOM's 12.0.23 pins
       so all Jetty modules are consistent (compile + test). Production runtime still uses 12.0.23 via OSGi. -->
  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.eclipse.jetty</groupId>
        <artifactId>jetty-bom</artifactId>
        <version>12.1.8</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>org.wiremock</groupId>
      <artifactId>wiremock-standalone</artifactId>
      <version>${wiremock.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>
</project>
